#include <iostream>
#include <string>
#include <chrono>
#include <memory>  
#include <vector>

// User authentication class
class User {
public:
    User(std::string username, std::string password)
        : username(username), password(password) {}

    bool authenticate(const std::string& u, const std::string& p) const {
        return u == username && p == password;
    }

private:
    std::string username;
    std::string password;
};

// Book class
class Book {
public:
    Book(std::string id, std::string title)
        : id(id), title(title) {}

    std::string getId() const { return id; }
    std::string getTitle() const { return title; }

private:
    std::string id;
    std::string title;
};

// Date class for handling dates
class Date {
public:
    Date() : tp(std::chrono::system_clock::now()) {}

    explicit Date(std::chrono::system_clock::time_point time)
        : tp(time) {}

    Date addDays(int days) const {
        return Date(tp + std::chrono::hours(24 * days));
    }

private:
    std::chrono::system_clock::time_point tp;
};

// Library Catalog class for managing books
class LibraryCatalog {
public:
    void addBook(const Book& book) {
        books.push_back(book);
    }

    void listBooks() const {
        for (const auto& b : books)
            std::cout << b.getId() << " | " << b.getTitle() << "\n";
    }

private:
    std::vector<Book> books;
};

// Main program
int main() {
    // User authentication demo
    User admin("admin", "admin");

    std::string username, password;
    std::cout << "Username: ";
    std::getline(std::cin, username);
    std::cout << "Password: ";
    std::getline(std::cin, password);

    if (admin.authenticate(username, password))
        std::cout << "Login successful.\n";
    else
        std::cout << "Invalid credentials.\n";

    // Library management demo
    std::cout << "\nSmart Library Management System\n";
    LibraryCatalog catalog;
    catalog.addBook(Book("B001", "Clean Code"));
    catalog.addBook(Book("B002", "Design Patterns"));
    std::cout << "Books in catalog:\n";
    catalog.listBooks();

    return 0;
}
