#include <iostream>
#include <string>
#include <vector>

enum class BookStatus { AVAILABLE, BORROWED };

class Book {
public:
    Book(std::string id, std::string title, std::string author)
        : id(id), title(title), author(author), status(BookStatus::AVAILABLE) {}

    std::string toString() const {
        return id + " | " + title + " | " + author;
    }

private:
    std::string id;
    std::string title;
    std::string author;
    BookStatus status;
};

int main() {
    std::vector<Book> books;
    books.emplace_back("B001", "Clean Code", "Robert Martin");

    std::cout << "Books:\n";
    for (const auto& b : books)
        std::cout << b.toString() << "\n";
}
