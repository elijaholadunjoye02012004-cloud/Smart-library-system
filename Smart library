struct Loan {
    std::shared_ptr<Book> book;
    std::shared_ptr<Member> member;
    Date borrowedDate;
    Date dueDate;
    bool returned = false;
};

struct Reservation {
    std::shared_ptr<Book> book;
    std::shared_ptr<Member> member;
    Date reservedDate;
};

class LibraryCatalog {
public:
    void addBook(const std::shared_ptr<Book>& book) {
        books[book->getId()] = book;
    }

    void updateBook(const std::shared_ptr<Book>& book) {
        books[book->getId()] = book;
    }

    void removeBook(const std::string& bookId) {
        books.erase(bookId);
    }

    std::shared_ptr<Book> findById(const std::string& bookId) const {
        auto it = books.find(bookId);
        return it == books.end() ? nullptr : it->second;
    }

    std::vector<std::shared_ptr<Book>> getAllBooks() const {
        std::vector<std::shared_ptr<Book>> result;
        for (const auto& pair : books) {
            result.push_back(pair.second);
        }
        return result;
    }

    std::vector<std::shared_ptr<Book>> searchByTitle(const std::string& query) const {
        std::vector<std::shared_ptr<Book>> results;
        for (const auto& pair : books) {
            if (toLower(pair.second->getTitle()).find(toLower(query)) != std::string::npos) {
                results.push_back(pair.second);
            }
        }
        return results;
    }

    std::vector<std::shared_ptr<Book>> searchByAuthor(const std::string& query) const {
        std::vector<std::shared_ptr<Book>> results;
        for (const auto& pair : books) {
            if (toLower(pair.second->getAuthor()).find(toLower(query)) != std::string::npos) {
                results.push_back(pair.second);
            }
        }
        return results;
    }

private:
    static std::string toLower(std::string value) {
        std::transform(value.begin(), value.end(), value.begin(),
                       [](unsigned char c) { return static_cast<char>(std::tolower(c)); });
        return value;
    }

    std::map<std::string, std::shared_ptr<Book>> books;
};

class AccountService {
public:
    void addUser(const std::shared_ptr<User>& user) {
        users[user->getUsername()] = user;
    }

    void removeUser(const std::string& username) {
        users.erase(username);
    }

    std::shared_ptr<User> authenticate(const std::string& username,
                                       const std::string& password) const {
        auto it = users.find(username);
        if (it == users.end()) {
            return nullptr;
        }
        return it->second->matchesPassword(password) ? it->second : nullptr;
    }

    const std::map<std::string, std::shared_ptr<User>>& getAllUsers() const {
        return users;
    }

private:
    std::map<std::string, std::shared_ptr<User>> users;
};

class BorrowService {
public:
    BorrowService(std::shared_ptr<LibraryCatalog> catalog,
                  std::shared_ptr<LibraryRules> rules)
        : catalog(std::move(catalog)), rules(std::move(rules)) {}

    std::string borrowBook(const std::shared_ptr<Member>& member,
                           const std::string& bookId,
                           const Date& today) {
        auto book = catalog->findById(bookId);
        if (!book) {
            return "Book not found.";
        }

        expireReservations(today);

        auto memberReservation = findReservation(book, member);
        if (book->getStatus() == BookStatus::RESERVED && !memberReservation) {
            return "Book is reserved by another member.";
        }
        if (book->getStatus() == BookStatus::BORROWED) {
            return "Book is already borrowed.";
        }

        if (countActiveLoans(member) >= member->getBorrowLimit(*rules)) {
            return "Borrow limit reached.";
        }

        Loan loan;
        loan.book = book;
        loan.member = member;
        loan.borrowedDate = today;
        loan.dueDate = today.addDays(rules->getLoanDays());
        loans.push_back(loan);

        book->setStatus(BookStatus::BORROWED);
        if (memberReservation) {
            removeReservation(memberReservation);
        }

        member->notify("Borrowed '" + book->getTitle() + "' due " + loan.dueDate.toString() + ".");
        return "Borrowed successfully.";
    }

    std::string returnBook(const std::shared_ptr<Member>& member,
                           const std::string& bookId,
                           const Date& today) {
        auto loan = findActiveLoan(bookId, member);
        if (!loan) {
            return "Loan not found.";
        }

        loan->returned = true;
        auto book = loan->book;

        auto nextReservation = findEarliestReservation(book);
        if (nextReservation) {
            book->setStatus(BookStatus::RESERVED);
            nextReservation->member->notify(
                "Reservation available for '" + book->getTitle() + "'."
            );
        } else {
            book->setStatus(BookStatus::AVAILABLE);
        }

        return "Return successful.";
    }

    std::string reserveBook(const std::shared_ptr<Member>& member,
                            const std::string& bookId,
                            const Date& today) {
        auto book = catalog->findById(bookId);
        if (!book) {
            return "Book not found.";
        }

        if (book->getStatus() == BookStatus::AVAILABLE) {
            return "Book is available; please borrow.";
        }
        if (findReservation(book, member)) {
            return "Already reserved.";
        }

        Reservation reservation;
        reservation.book = book;
        reservation.member = member;
        reservation.reservedDate = today;
        reservations.push_back(reservation);
        book->setStatus(BookStatus::RESERVED);
        member->notify("Reservation placed for '" + book->getTitle() + "'.");
        return "Reservation successful.";
    }

    std::vector<Loan> getOverdueLoans(const Date& today) const {
        std::vector<Loan> overdue;
        for (const auto& loan : loans) {
            if (!loan.returned && loan.dueDate.isBefore(today)) {
                overdue.push_back(loan);
            }
        }
        return overdue;
    }

    std::vector<Loan> getActiveLoansForMember(const std::shared_ptr<Member>& member) const {
        std::vector<Loan> active;
        for (const auto& loan : loans) {
            if (!loan.returned && loan.member->getId() == member->getId()) {
                active.push_back(loan);
            }
        }
        return active;
    }

    std::vector<Reservation> getReservationsForMember(const std::shared_ptr<Member>& member) const {
        std::vector<Reservation> result;
        for (const auto& reservation : reservations) {
            if (reservation.member->getId() == member->getId()) {
                result.push_back(reservation);
            }
        }
        return result;
    }

private:
    int countActiveLoans(const std::shared_ptr<Member>& member) const {
        int count = 0;
        for (const auto& loan : loans) {
            if (!loan.returned && loan.member->getId() == member->getId()) {
                count++;
            }
        }
        return count;
    }

    Loan* findActiveLoan(const std::string& bookId, const std::shared_ptr<Member>& member) {
        for (auto& loan : loans) {
            if (!loan.returned
                && loan.member->getId() == member->getId()
                && loan.book->getId() == bookId) {
                return &loan;
            }
        }
        return nullptr;
    }

    Reservation* findReservation(const std::shared_ptr<Book>& book,
                                 const std::shared_ptr<Member>& member) {
        for (auto& reservation : reservations) {
            if (reservation.book->getId() == book->getId()
                && reservation.member->getId() == member->getId()) {
                return &reservation;
            }
        }
        return nullptr;
    }

    Reservation* findEarliestReservation(const std::shared_ptr<Book>& book) {
        Reservation* earliest = nullptr;
        for (auto& reservation : reservations) {
            if (reservation.book->getId() != book->getId()) {
                continue;
            }
            if (!earliest || reservation.reservedDate.isBefore(earliest->reservedDate)) {
                earliest = &reservation;
            }
        }
        return earliest;
    }

    void removeReservation(Reservation* reservation) {
        reservations.erase(std::remove_if(reservations.begin(), reservations.end(),
                                          [&](const Reservation& r) {
                                              return r.book->getId() == reservation->book->getId()
                                                  && r.member->getId() == reservation->member->getId();
                                          }),
                           reservations.end());
    }

    void expireReservations(const Date& today) {
        reservations.erase(std::remove_if(reservations.begin(), reservations.end(),
                                          [&](const Reservation& r) {
                                              return r.reservedDate
                                                  .addDays(rules->getReservationExpiryDays())
                                                  .isBefore(today);
                                          }),
                           reservations.end());
    }

    std::shared_ptr<LibraryCatalog> catalog;
    std::shared_ptr<LibraryRules> rules;
    std::vector<Loan> loans;
    std::vector<Reservation> reservations;
};

class LibrarySystem {
public:
    LibrarySystem()
        : rules(std::make_shared<LibraryRules>()),
          catalog(std::make_shared<LibraryCatalog>()),
          accounts(std::make_shared<AccountService>()),
          borrowService(std::make_shared<BorrowService>(catalog, rules)) {
        seedData();
    }

    std::shared_ptr<LibraryRules> getRules() const { return rules; }
    std::shared_ptr<LibraryCatalog> getCatalog() const { return catalog; }
    std::shared_ptr<AccountService> getAccounts() const { return accounts; }
    std::shared_ptr<BorrowService> getBorrowService() const { return borrowService; }

private:
    void seedData() {
        auto notifier = std::make_shared<ConsoleNotification>();

        catalog->addBook(std::make_shared<Book>("B001", "Clean Code", "Robert C. Martin"));
        catalog->addBook(std::make_shared<Book>("B002", "Effective Java", "Joshua Bloch"));
        catalog->addBook(std::make_shared<Book>("B003", "Design Patterns", "GoF"));

        accounts->addUser(std::make_shared<Member>("M001", "Alice Member", "alice", "pass1", notifier));
        accounts->addUser(std::make_shared<Member>("M002", "Bob Member", "bob", "pass2", notifier));
        accounts->addUser(std::make_shared<Librarian>("L001", "Lina Librarian", "lina", "lib1", notifier));
        accounts->addUser(std::make_shared<Admin>("A001", "Adam Admin", "adam", "admin1", notifier));

        auto alice = std::dynamic_pointer_cast<Member>(
            accounts->authenticate("alice", "pass1"));
        if (alice) {
            borrowService->borrowBook(alice, "B001", Date::today().addDays(-20));
        }
    }

    std::shared_ptr<LibraryRules> rules;
    std::shared_ptr<LibraryCatalog> catalog;
    std::shared_ptr<AccountService> accounts;
    std::shared_ptr<BorrowService> borrowService;
};

static std::string readLine(const std::string& prompt) {
    std::cout << prompt;
    std::string input;
    std::getline(std::cin, input);
    return input;
}

static int readInt(const std::string& prompt) {
    while (true) {
        std::string input = readLine(prompt);
        try {
            return std::stoi(input);
        } catch (...) {
            std::cout << "Please enter a number.\n";
        }
    }
}

static double readDouble(const std::string& prompt) {
    while (true) {
        std::string input = readLine(prompt);
        try {
            return std::stod(input);
        } catch (...) {
            std::cout << "Please enter a decimal number.\n";
        }
    }
}

static void searchByTitle(const std::shared_ptr<LibrarySystem>& system) {
