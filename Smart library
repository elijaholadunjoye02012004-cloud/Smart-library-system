                system->getAccounts()->removeUser(username);
                std::cout << "User removed.\n";
                break;
            }
            case 3:
                updateRules(system);
                break;
            case 4: {
                const auto& users = system->getAccounts()->getAllUsers();
                for (const auto& entry : users) {
                    std::cout << entry.first << " | ";
                    switch (entry.second->getRole()) {
                        case UserRole::MEMBER:
                            std::cout << "MEMBER";
                            break;
                        case UserRole::LIBRARIAN:
                            std::cout << "LIBRARIAN";
                            break;
                        case UserRole::ADMIN:
                            std::cout << "ADMIN";
                            break;
                    }
                    std::cout << "\n";
                }
                break;
            }
            case 0:
                return;
            default:
                std::cout << "Invalid choice.\n";
        }
    }
}

int main() {
    auto system = std::make_shared<LibrarySystem>();

    std::cout << "Smart Library Management System (SLMS)\n";
    while (true) {
        std::string username = readLine("\nUsername (or 'exit'): ");
        if (username == "exit") {
            break;
        }
        std::string password = readLine("Password: ");

        auto user = system->getAccounts()->authenticate(username, password);
        if (!user) {
            std::cout << "Invalid credentials.\n";
            continue;
        }

        if (user->getRole() == UserRole::MEMBER) {
            memberMenu(system, std::dynamic_pointer_cast<Member>(user));
        } else if (user->getRole() == UserRole::LIBRARIAN) {
            librarianMenu(system);
        } else if (user->getRole() == UserRole::ADMIN) {
            adminMenu(system);
        }
    }

    std::cout << "Goodbye.\n";
    return 0;
}

