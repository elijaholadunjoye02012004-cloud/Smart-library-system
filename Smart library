class Date {
public:
    Date() : tp(std::chrono::system_clock::now()) {}
    explicit Date(std::chrono::system_clock::time_point t) : tp(t) {}

    static Date today() {
        return Date(std::chrono::system_clock::now());
    }

    Date addDays(int days) const {
        return Date(tp + std::chrono::hours(24 * days));
    }

    bool isBefore(const Date& other) const {
        return tp < other.tp;
    }

    int daysUntil(const Date& other) const {
        auto diff = other.tp - tp;
        return static_cast<int>(
            std::chrono::duration_cast<std::chrono::hours>(diff).count() / 24
        );
    }

    std::string toString() const {
        std::time_t time = std::chrono::system_clock::to_time_t(tp);
        std::tm tm{};
#if defined(_WIN32)
        localtime_s(&tm, &time);
#else
        localtime_r(&time, &tm);
#endif
        std::ostringstream out;
        out << std::put_time(&tm, "%Y-%m-%d");
        return out.str();
    }

private:
    std::chrono::system_clock::time_point tp;
};

enum class BookStatus {
    AVAILABLE,
    BORROWED,
    RESERVED
};

static std::string bookStatusToString(BookStatus status) {
    switch (status) {
        case BookStatus::AVAILABLE:
            return "AVAILABLE";
        case BookStatus::BORROWED:
            return "BORROWED";
        case BookStatus::RESERVED:
            return "RESERVED";
        default:
            return "UNKNOWN";
    }
}

class Book {
public:
    Book(std::string id, std::string title, std::string author)
        : id(std::move(id)), title(std::move(title)),
          author(std::move(author)), status(BookStatus::AVAILABLE) {}

    const std::string& getId() const { return id; }
    const std::string& getTitle() const { return title; }
    const std::string& getAuthor() const { return author; }
    BookStatus getStatus() const { return status; }

    void setTitle(const std::string& newTitle) { title = newTitle; }
    void setAuthor(const std::string& newAuthor) { author = newAuthor; }
    void setStatus(BookStatus newStatus) { status = newStatus; }

    bool isAvailable() const { return status == BookStatus::AVAILABLE; }

    std::string toString() const {
        std::ostringstream out;
        out << id << " | " << title << " | " << author << " | "
            << bookStatusToString(status);
        return out.str();
    }

private:
    std::string id;
    std::string title;
    std::string author;
    BookStatus status;
};

enum class UserRole {
    MEMBER,
    LIBRARIAN,
    ADMIN
};

class User;

class NotificationChannel {
public:
    virtual ~NotificationChannel() = default;
    virtual void send(const User& user, const std::string& message) = 0;
};

class User {
public:
    User(std::string id,
         std::string name,
         std::string username,
         std::string password,
         std::shared_ptr<NotificationChannel> notifier)
        : id(std::move(id)),
          name(std::move(name)),
          username(std::move(username)),
          password(std::move(password)),
          notifier(std::move(notifier)) {}

    virtual ~User() = default;

    const std::string& getId() const { return id; }
    const std::string& getName() const { return name; }
    const std::string& getUsername() const { return username; }

    bool matchesPassword(const std::string& input) const {
        return password == input;
    }

    virtual UserRole getRole() const = 0;

    void notify(const std::string& message) const {
        if (notifier) {
            notifier->send(*this, message);
        }
    }

private:
    std::string id;
    std::string name;
    std::string username;
    std::string password;
    std::shared_ptr<NotificationChannel> notifier;
};

