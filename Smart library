                std::string id = readLine("Book ID to remove: ");
                system->getCatalog()->removeBook(id);
                std::cout << "Book removed.\n";
                break;
            }
            case 4: {
                auto overdue = system->getBorrowService()->getOverdueLoans(Date::today());
                if (overdue.empty()) {
                    std::cout << "No overdue loans.\n";
                } else {
                    for (const auto& loan : overdue) {
                        std::cout << loan.book->getId() << " | " << loan.book->getTitle()
                                  << " | member " << loan.member->getUsername()
                                  << " | due " << loan.dueDate.toString() << "\n";
                    }
                }
                break;
            }
            case 5: {
                auto books = system->getCatalog()->getAllBooks();
                for (const auto& book : books) {
                    std::cout << book->toString() << "\n";
                }
                break;
            }
            case 0:
                return;
            default:
                std::cout << "Invalid choice.\n";
        }
    }
}

static void addUser(const std::shared_ptr<LibrarySystem>& system) {
    std::string role = readLine("Role (member/librarian/admin): ");
    std::string id = readLine("User ID: ");
    std::string name = readLine("Name: ");
    std::string username = readLine("Username: ");
    std::string password = readLine("Password: ");
    auto notifier = std::make_shared<ConsoleNotification>();

    if (role == "member") {
        system->getAccounts()->addUser(
            std::make_shared<Member>(id, name, username, password, notifier));
    } else if (role == "librarian") {
        system->getAccounts()->addUser(
            std::make_shared<Librarian>(id, name, username, password, notifier));
    } else if (role == "admin") {
        system->getAccounts()->addUser(
            std::make_shared<Admin>(id, name, username, password, notifier));
    } else {
        std::cout << "Unknown role.\n";
        return;
    }
    std::cout << "User added.\n";
}

static void updateRules(const std::shared_ptr<LibrarySystem>& system) {
    auto rules = system->getRules();
    int borrowLimit = readInt("Borrow limit: ");
    int reservationDays = readInt("Reservation expiry (days): ");
    int loanDays = readInt("Loan period (days): ");
    double latePenalty = readDouble("Late penalty per day: ");

    rules->setBorrowLimit(borrowLimit);
    rules->setReservationExpiryDays(reservationDays);
    rules->setLoanDays(loanDays);
    rules->setLatePenaltyPerDay(latePenalty);
    std::cout << "Rules updated.\n";
}

