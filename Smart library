#include <iostream>
#include <string>
#include <chrono>
#include <vector>

// ============================================
// UTILITY CLASSES
// ============================================

// Date class for handling dates
class Date {
public:
    Date() : tp(std::chrono::system_clock::now()) {}

    Date addDays(int days) const {
        return Date(tp + std::chrono::hours(24 * days));
    }

private:
    std::chrono::system_clock::time_point tp;
    Date(std::chrono::system_clock::time_point t) : tp(t) {}
};

// ============================================
// AUTHENTICATION
// ============================================

// User authentication class
class User {
public:
    User(std::string username, std::string password)
        : username(username), password(password) {}

    bool authenticate(const std::string& u, const std::string& p) const {
        return u == username && p == password;
    }

private:
    std::string username;
    std::string password;
};

// ============================================
// ROLES & PERMISSIONS
// ============================================

enum class Role { MEMBER, LIBRARIAN };

// ============================================
// LIBRARY RULES
// ============================================

class LibraryRules {
public:
    int borrowLimit = 5;
    int loanDays = 14;
};

// ============================================
// LIBRARY COMPONENTS
// ============================================

// Reservation structure
struct Reservation {
    std::string bookId;
    std::string username;
};

// Book class
class Book {
public:
    Book(std::string id, std::string title)
        : id(id), title(title), borrowed(false) {}

    void borrow() { borrowed = true; }
    bool isBorrowed() const { return borrowed; }

    std::string getId() const { return id; }
    std::string getTitle() const { return title; }

private:
    std::string id;
    std::string title;
    bool borrowed;
};

// Library Catalog class for managing books
class LibraryCatalog {
public:
    void addBook(const Book& book) {
        books.push_back(book);
    }

    void listBooks() const {
        for (const auto& b : books)
            std::cout << b.getId() << " | " << b.getTitle() << "\n";
    }

private:
    std::vector<Book> books;
};

// Reservations Manager
class ReservationManager {
public:
    void addReservation(const Reservation& reservation) {
        reservations.push_back(reservation);
    }

    void listReservations() const {
        for (const auto& r : reservations)
            std::cout << "  Book: " << r.bookId << " | User: " << r.username << "\n";
    }

private:
    std::vector<Reservation> reservations;
};

// ============================================
// MAIN PROGRAM
// ============================================

int main() {
    std::cout << "=== Smart Library Management System ===\n\n";

    // Step 1: User Authentication
    std::cout << "--- User Authentication ---\n";
    User admin("admin", "admin");

    std::string username, password;
    std::cout << "Username: ";
    std::getline(std::cin, username);
    std::cout << "Password: ";
    std::getline(std::cin, password);

    if (!admin.authenticate(username, password)) {
        std::cout << "Invalid credentials.\n";
        return 1;
    }
    std::cout << "Login successful.\n\n";

    // Step 2: Book Borrowing
    std::cout << "--- Book Borrowing ---\n";
    Book book("B001", "Clean Code");
    if (!book.isBorrowed()) {
        book.borrow();
        std::cout << "Book '" << book.getTitle() << "' borrowed successfully.\n\n";
    }

    // Step 3: Loan Date Management
    std::cout << "--- Loan Date ---\n";
    Date today;
    Date due = today.addDays(14);
    std::cout << "Loan created with 14-day due date.\n\n";

    // Step 4: Book Reservations
    std::cout << "--- Book Reservations ---\n";
    ReservationManager reservationMgr;
    reservationMgr.addReservation({"B001", "alice"});
    reservationMgr.addReservation({"B002", "bob"});
    std::cout << "Active Reservations:\n";
    reservationMgr.listReservations();
    std::cout << "\n";

    // Step 5: User Roles 
    std::cout << "--- User Roles ---\n";
    Role userRole = Role::MEMBER;
    if (userRole == Role::MEMBER)
        std::cout << "Member Menu\n";
    else
        std::cout << "Librarian Menu\n";
    std::cout << "\n";

    // Step 6: Library Rules 
    std::cout << "--- Library Rules ---\n";
    LibraryRules rules;
    std::cout << "Borrow limit: " << rules.borrowLimit << "\n";
    std::cout << "Loan days: " << rules.loanDays << "\n";

    return 0;
}
