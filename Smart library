#include <iostream>
#include <string>
#include <chrono>
#include <vector>
#include <ctime>

// ============================================
// ROLES
// ============================================

enum class Role { MEMBER, LIBRARIAN };

// ============================================
// UTILITY CLASSES
// ============================================

class Date {
public:
    Date() : tp(std::chrono::system_clock::now()) {}

    Date addDays(int days) const {
        return Date(tp + std::chrono::hours(24 * days));
    }

    void print() const {
        std::time_t t = std::chrono::system_clock::to_time_t(tp);
        std::cout << std::ctime(&t);
    }

private:
    std::chrono::system_clock::time_point tp;

    Date(std::chrono::system_clock::time_point t) : tp(t) {}
};

// ============================================
// USER AUTHENTICATION
// ============================================

class User {
public:
    User(std::string username, std::string password, Role role)
        : username(username), password(password), role(role) {}

    bool authenticate(const std::string& u, const std::string& p) const {
        return u == username && p == password;
    }

    Role getRole() const {
        return role;
    }

    std::string getUsername() const {
        return username;
    }

private:
    std::string username;
    std::string password;
    Role role;
};

// ============================================
// LIBRARY RULES
// ============================================

class LibraryRules {
public:
    int borrowLimit = 5;
    int loanDays = 14;
};

// ============================================
// LIBRARY COMPONENTS
// ============================================

struct Reservation {
    std::string bookId;
    std::string username;
};

class Book {
public:
    Book(std::string id, std::string title)
        : id(id), title(title), borrowed(false) {}

    bool borrow() {
        if (borrowed)
            return false;

        borrowed = true;
        return true;
    }

    void returnBook() {
        borrowed = false;
    }

    bool isBorrowed() const {
        return borrowed;
    }

    std::string getId() const {
        return id;
    }

    std::string getTitle() const {
        return title;
    }

private:
    std::string id;
    std::string title;
    bool borrowed;
};

class LibraryCatalog {
public:
    void addBook(const Book& book) {
        books.push_back(book);
    }

    void listBooks() const {
        for (const auto& b : books)
            std::cout << b.getId() << " | " << b.getTitle() << "\n";
    }

private:
    std::vector<Book> books;
};

class ReservationManager {
public:
    void addReservation(const Reservation& reservation) {
        reservations.push_back(reservation);
    }

    void listReservations() const {
        for (const auto& r : reservations)
            std::cout << "Book: " << r.bookId << " | User: " << r.username << "\n";
    }

private:
    std::vector<Reservation> reservations;
};

// ============================================
// MAIN PROGRAM
// ============================================

int main() {

    std::cout << "=== Smart Library Management System ===\n\n";

    // ============================================
    // USER LIST
    // ============================================

    std::vector<User> users = {
        User("admin", "admin123", Role::LIBRARIAN),
        User("librarian", "lib123", Role::LIBRARIAN),
        User("member", "mem123", Role::MEMBER)
    };

    // ============================================
    // LOGIN
    // ============================================

    std::string username, password;

    std::cout << "--- User Authentication ---\n";

    std::cout << "Username: ";
    std::getline(std::cin, username);

    std::cout << "Password: ";
    std::getline(std::cin, password);

    User* loggedUser = nullptr;

    for (auto& user : users) {
        if (user.authenticate(username, password)) {
            loggedUser = &user;
            break;
        }
    }

    if (!loggedUser) {
        std::cout << "Invalid credentials.\n";
        return 1;
    }

    std::cout << "Login successful. Welcome " << loggedUser->getUsername() << "\n\n";

    // ============================================
    // USER ROLE MENU
    // ============================================

    std::cout << "--- User Role ---\n";

    if (loggedUser->getRole() == Role::LIBRARIAN) {

        std::cout << "Librarian/Admin Menu\n";
        std::cout << "1. Add Book\n";
        std::cout << "2. View Reservations\n";
        std::cout << "3. Manage Catalog\n";

    }
    else {

        std::cout << "Member Menu\n";
        std::cout << "1. Borrow Book\n";
        std::cout << "2. Reserve Book\n";
        std::cout << "3. View Borrowed Books\n";

    }

    std::cout << "\n";

    // ============================================
    // BOOK BORROWING DEMO
    // ============================================

    std::cout << "--- Book Borrowing ---\n";

    Book book("B001", "Clean Code");

    if (book.borrow()) {
        std::cout << "Book '" << book.getTitle() << "' borrowed successfully.\n";
    } else {
        std::cout << "Book already borrowed.\n";
    }

    std::cout << "\n";

    // ============================================
    // LOAN DATE DEMO
    // ============================================

    std::cout << "--- Loan Date ---\n";

    Date today;
    Date due = today.addDays(14);

    std::cout << "Due date: ";
    due.print();

    std::cout << "\n";

    // ============================================
    // RESERVATION DEMO
    // ============================================

    std::cout << "--- Book Reservations ---\n";

    ReservationManager reservationMgr;

    reservationMgr.addReservation({"B001", "alice"});
    reservationMgr.addReservation({"B002", "bob"});

    std::cout << "Active Reservations:\n";

    reservationMgr.listReservations();

    std::cout << "\n";

    // ============================================
    // LIBRARY RULES
    // ============================================

    std::cout << "--- Library Rules ---\n";

    LibraryRules rules;

    std::cout << "Borrow limit: " << rules.borrowLimit << "\n";
    std::cout << "Loan days: " << rules.loanDays << "\n";

    return 0;
}
