#include <iostream>
#include <string>
#include <chrono>
#include <memory>  

enum class BookStatus { AVAILABLE, BORROWED, RESERVED };

class Book {
public:
    Book(std::string id, std::string title, std::string author)
        : id(id), title(title), author(author),
          status(BookStatus::AVAILABLE) {}

    std::string getId() const { return id; }
    std::string getTitle() const { return title; }
    BookStatus getStatus() const { return status; }

private:
    std::string id;
    std::string title;
    std::string author;
    BookStatus status;
};

int main() {
    std::cout << "Smart Library Management System\n";
}

class Date {
public:
    Date() : tp(std::chrono::system_clock::now()) {}

    explicit Date(std::chrono::system_clock::time_point time)
        : tp(time) {}

    Date addDays(int days) const {
        return Date(tp + std::chrono::hours(24 * days));
    }

private:
    std::chrono::system_clock::time_point tp;
};

// Loan Structure
struct Loan {
    std::shared_ptr<Book> book;
    Date borrowedDate;
    Date dueDate;
};
